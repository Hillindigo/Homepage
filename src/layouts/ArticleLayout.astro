---
import BaseLayout from './BaseLayout.astro';
import Comments from '../components/Comments.astro';
import ShareActions from '../components/ShareActions.astro';
import { getCollection } from 'astro:content';
const { entry, readingMinutes, headings=[], section='WRITING', comments=true, navigation={} } = Astro.props;
const { title, description, pubDate, updatedDate, tags, lang } = entry.data;
const date = new Intl.DateTimeFormat(lang==='zh'?'zh-CN':'en-US',{dateStyle:'long'});
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projectLinks = section==='PROJECTS' ? [
  entry.data.website&&{label:lang==='zh'?'访问项目':'Visit project',href:entry.data.website},
  entry.data.repository&&{label:lang==='zh'?'查看源码':'Source code',href:entry.data.repository},
].filter(Boolean) : [];
const otherLang = lang==='zh'?'en':'zh';
let candidates:any[]=[];
if(section==='WRITING') candidates=await getCollection('blog',({data})=>!data.draft);
if(section==='NOTES') candidates=await getCollection('notes',({data})=>!data.draft);
if(section==='PROJECTS') candidates=await getCollection('projects',({data})=>!data.draft);
if(section==='LIFE') candidates=await getCollection('life',({data})=>!data.draft);
const translation=entry.data.translationKey?candidates.find(item=>item.data.lang===otherLang&&item.data.translationKey===entry.data.translationKey):undefined;
const route=section==='WRITING'?'writing':section.toLowerCase();
const translationSlug=translation?.id.replace(`${otherLang}/`,'');
const alternatePath=translation?`${base}/${otherLang}/${route}/${translationSlug}/`:`${base}/${otherLang}/`;
---
<BaseLayout lang={lang} title={`${title} · Hillindigo`} description={description} alternatePath={alternatePath}>
  <div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>
  <main class="article-shell shell" data-pagefind-body>
    <article class="article">
      <header class="article-header"><p class="eyebrow">HILLINDIGO / {section}</p><h1>{title}</h1><p class="article-description">{description}</p><div class="article-meta"><time datetime={pubDate.toISOString()}>{date.format(pubDate)}</time><span>{readingMinutes} {lang==='zh'?'分钟阅读':'min read'}</span>{updatedDate&&<span>{lang==='zh'?'更新于':'Updated'} {date.format(updatedDate)}</span>}</div><div class="article-tags">{tags.map((tag:string)=><a href={`${base}/${lang}/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}</div>{projectLinks.length>0&&<div class="article-actions">{projectLinks.map((link:any)=><a href={link.href} target="_blank" rel="noreferrer">{link.label} ↗</a>)}</div>}</header>
      <div class="article-layout"><aside class="toc"><p class="eyebrow">{lang==='zh'?'目录':'CONTENTS'}</p><nav>{headings.filter((h:any)=>h.depth<=3).map((h:any)=><a class={`depth-${h.depth}`} href={`#${h.slug}`}>{h.text}</a>)}</nav></aside><div class="prose"><slot/></div></div>
      <ShareActions lang={lang} title={title}/>
      {(navigation.previous||navigation.next)&&<nav class="article-navigation" aria-label={lang==='zh'?'文章导航':'Article navigation'}>{navigation.previous?<a href={navigation.previous.href}><span>{lang==='zh'?'上一篇':'Previous'}</span><strong>{navigation.previous.title}</strong></a>:<i></i>}{navigation.next&&<a class="next" href={navigation.next.href}><span>{lang==='zh'?'下一篇':'Next'}</span><strong>{navigation.next.title}</strong></a>}</nav>}
      {comments&&<Comments lang={lang}/>} 
    </article>
  </main>
  <script>
    const article=document.querySelector<HTMLElement>('.article');
    const progress=document.querySelector<HTMLElement>('[data-reading-progress]');
    let scheduled=false;
    const updateProgress=()=>{scheduled=false;if(!article||!progress)return;const start=article.offsetTop;const distance=Math.max(1,article.offsetHeight-window.innerHeight);const value=Math.min(1,Math.max(0,(window.scrollY-start)/distance));progress.style.transform=`scaleX(${value})`;};
    const schedule=()=>{if(!scheduled){scheduled=true;requestAnimationFrame(updateProgress)}};
    window.addEventListener('scroll',schedule,{passive:true});window.addEventListener('resize',schedule);updateProgress();
    const links=[...document.querySelectorAll<HTMLAnchorElement>('.toc a')];
    const headings=[...document.querySelectorAll<HTMLElement>('.prose h2[id],.prose h3[id]')];
    const setActive=(id:string)=>links.forEach(link=>link.toggleAttribute('aria-current',decodeURIComponent(link.hash.slice(1))===id));
    const updateActive=()=>{if(!headings.length)return;const current=[...headings].reverse().find(heading=>heading.getBoundingClientRect().top<=170)??headings[0];setActive(current.id);};
    window.addEventListener('scroll',updateActive,{passive:true});updateActive();
  </script>
</BaseLayout>
