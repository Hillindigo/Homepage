---
import '../styles/global.css';
import Header from '../components/Header.astro';
const { title='青山黛 · Hillindigo', description='记录 AI Agent、软件工程、知识系统与生活。', lang='zh', header=true } = Astro.props;
---
<!doctype html><html lang={lang} data-theme="dark"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="description" content={description}/><meta name="generator" content={Astro.generator}/><link rel="alternate" type="application/rss+xml" title="Hillindigo RSS" href={`${import.meta.env.BASE_URL}${lang}/rss.xml`}/><title>{title}</title><script is:inline>const t=localStorage.getItem('theme');if(t)document.documentElement.dataset.theme=t;</script></head><body>{header&&<Header lang={lang}/>}<slot/><footer class="footer"><div class="shell"><span>© 2026 HILLINDIGO</span><span>BUILT WITH ASTRO · WORDS IN ORBIT</span></div></footer><script>document.querySelector('[data-theme-toggle]')?.addEventListener('click',()=>{const root=document.documentElement;const next=root.dataset.theme==='light'?'dark':'light';root.dataset.theme=next;localStorage.setItem('theme',next)});</script></body></html>
