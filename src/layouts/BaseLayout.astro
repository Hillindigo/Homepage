---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Lightbox from '../components/Lightbox.astro';
import Analytics from '../components/Analytics.astro';
const { title='青山黛 · Hillindigo', description='记录 AI Agent、软件工程、知识系统与生活。', lang='zh', header=true, footer=true, alternatePath, structuredData, ogType='website', publishedTime, modifiedTime } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const socialImage = new URL(`${base}/images/social-card.jpg`, Astro.site);
const otherLang = lang==='zh'?'en':'zh';
const resolvedAlternate = alternatePath || Astro.url.pathname.replace(`/${lang}/`,`/${otherLang}/`);
const alternateUrl = new URL(resolvedAlternate, Astro.site);
const currentLocale = lang==='zh'?'zh_CN':'en_US';
const otherLocale = lang==='zh'?'en_US':'zh_CN';
const currentHreflang = lang==='zh'?'zh-CN':'en';
const otherHreflang = lang==='zh'?'en':'zh-CN';
const defaultUrl = new URL(`${base}/`, Astro.site);
const socialImageAlt = lang==='zh'?'青山黛 Hillindigo 社交分享封面':'Hillindigo social sharing cover';
const rememberLanguage = Astro.url.pathname.includes(`/${lang}/`);
const defaultStructuredData = { '@context':'https://schema.org', '@type':'WebSite', name:'青山黛 · Hillindigo', url:new URL(`${base}/`,Astro.site).href, inLanguage:['zh-CN','en'] };
const jsonLd = structuredData || defaultStructuredData;
---
<!doctype html><html lang={lang} data-theme="dark"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="theme-color" content="#050706"/><meta name="description" content={description}/><meta name="generator" content={Astro.generator}/><meta property="og:type" content={ogType}/><meta property="og:site_name" content="Hillindigo"/><meta property="og:locale" content={currentLocale}/><meta property="og:locale:alternate" content={otherLocale}/><meta property="og:url" content={canonical}/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:image" content={socialImage}/><meta property="og:image:alt" content={socialImageAlt}/><meta property="og:image:width" content="1200"/><meta property="og:image:height" content="630"/><meta property="og:image:type" content="image/jpeg"/><meta name="twitter:card" content="summary_large_image"/><meta name="twitter:title" content={title}/><meta name="twitter:description" content={description}/><meta name="twitter:image" content={socialImage}/><meta name="twitter:image:alt" content={socialImageAlt}/>{publishedTime&&<meta property="article:published_time" content={publishedTime}/>} {modifiedTime&&<meta property="article:modified_time" content={modifiedTime}/>}<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}/><link rel="icon" href={`${base}/images/avatar.png`}/><link rel="apple-touch-icon" href={`${base}/images/avatar.png`}/><link rel="manifest" href={`${base}/site.webmanifest`}/><link rel="canonical" href={canonical}/><link rel="alternate" hreflang={currentHreflang} href={canonical}/><link rel="alternate" hreflang={otherHreflang} href={alternateUrl}/><link rel="alternate" hreflang="x-default" href={defaultUrl}/><link rel="alternate" type="application/rss+xml" title="Hillindigo RSS" href={`${base}/${lang}/rss.xml`}/><title>{title}</title><script is:inline>const savedTheme=localStorage.getItem('theme');const themePreference=savedTheme==='light'||savedTheme==='dark'?savedTheme:'system';const systemTheme=matchMedia('(prefers-color-scheme:light)').matches?'light':'dark';const initialTheme=themePreference==='system'?systemTheme:themePreference;document.documentElement.dataset.theme=initialTheme;document.documentElement.dataset.themePreference=themePreference;document.querySelector('meta[name="theme-color"]')?.setAttribute('content',initialTheme==='light'?'#f3efe4':'#050706');</script><script is:inline define:vars={{rememberLanguage,lang}}>if(rememberLanguage){try{localStorage.setItem('hillindigo-language',lang)}catch{}}</script><Analytics/></head><body><a class="skip-link" href="#main-content">{lang==='zh'?'跳到主要内容':'Skip to content'}</a>{header&&<Header lang={lang} alternatePath={resolvedAlternate}/>}<div id="main-content" tabindex="-1"><slot/></div>{footer&&<footer class="footer"><div class="shell"><div><strong>青山黛 · HILLINDIGO</strong><span>{lang==='zh'?'记录技术、系统与有温度的生活。':'Technology, systems and a life well made.'}</span></div><nav aria-label={lang==='zh'?'页脚导航':'Footer navigation'}><a href={`${base}/${lang}/writing/`}>{lang==='zh'?'文章':'Writing'}</a><a href={`${base}/${lang}/search/`}>{lang==='zh'?'搜索':'Search'}</a><a href={`${base}/${lang}/archive/`}>{lang==='zh'?'归档':'Archive'}</a><a href={`${base}/${lang}/tags/`}>{lang==='zh'?'标签':'Tags'}</a><a href={`${base}/${lang}/rss.xml`}>RSS</a><a href="https://github.com/Hillindigo/Homepage" target="_blank" rel="noreferrer">GitHub ↗</a></nav><span>© 2026 · BUILT WITH ASTRO</span></div></footer>}<Lightbox lang={lang}/><script>type Theme='light'|'dark';type ThemePreference=Theme|'system';const toggle=document.querySelector<HTMLButtonElement>('[data-theme-toggle]');const themeMedia=matchMedia('(prefers-color-scheme:light)');const preferences:ThemePreference[]=['system','light','dark'];const getPreference=():ThemePreference=>{const value=document.documentElement.dataset.themePreference;return value==='light'||value==='dark'?value:'system'};const resolveTheme=(preference:ThemePreference):Theme=>preference==='system'?(themeMedia.matches?'light':'dark'):preference;const updateControl=(preference:ThemePreference)=>{if(!toggle)return;const zh=document.documentElement.lang==='zh';const next=preferences[(preferences.indexOf(preference)+1)%preferences.length];const names=zh?{system:'跟随系统',light:'浅色',dark:'深色'}:{system:'System',light:'Light',dark:'Dark'};const label=zh?`主题：${names[preference]}。切换为${names[next]}`:`Theme: ${names[preference]}. Switch to ${names[next]}`;toggle.textContent={system:'◐',light:'☀',dark:'☾'}[preference];toggle.setAttribute('aria-label',label);toggle.title=label};const applyTheme=(theme:Theme)=>{document.documentElement.dataset.theme=theme;document.querySelector('meta[name="theme-color"]')?.setAttribute('content',theme==='light'?'#f3efe4':'#050706');document.querySelector<HTMLIFrameElement>('iframe.giscus-frame')?.contentWindow?.postMessage({giscus:{setConfig:{theme}}},'https://giscus.app')};const setPreference=(preference:ThemePreference,persist=true)=>{document.documentElement.dataset.themePreference=preference;if(persist){if(preference==='system')localStorage.removeItem('theme');else localStorage.setItem('theme',preference)}applyTheme(resolveTheme(preference));updateControl(preference)};setPreference(getPreference(),false);toggle?.addEventListener('click',()=>{const current=getPreference();setPreference(preferences[(preferences.indexOf(current)+1)%preferences.length])});themeMedia.addEventListener('change',()=>{if(getPreference()==='system')applyTheme(resolveTheme('system'))});</script></body></html>
