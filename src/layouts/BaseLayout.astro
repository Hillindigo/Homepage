---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Lightbox from '../components/Lightbox.astro';
const { title='青山黛 · Hillindigo', description='记录 AI Agent、软件工程、知识系统与生活。', lang='zh', header=true } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const socialImage = new URL(`${base}/images/avatar.png`, Astro.site);
---
<!doctype html><html lang={lang} data-theme="dark"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="description" content={description}/><meta name="generator" content={Astro.generator}/><meta property="og:type" content="website"/><meta property="og:site_name" content="Hillindigo"/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:image" content={socialImage}/><link rel="canonical" href={canonical}/><link rel="alternate" type="application/rss+xml" title="Hillindigo RSS" href={`${base}/${lang}/rss.xml`}/><title>{title}</title><script is:inline>const t=localStorage.getItem('theme');if(t)document.documentElement.dataset.theme=t;</script></head><body>{header&&<Header lang={lang}/>}<slot/><footer class="footer"><div class="shell"><span>© 2026 HILLINDIGO</span><span>BUILT WITH ASTRO · WORDS IN ORBIT</span></div></footer><Lightbox/><script>document.querySelector('[data-theme-toggle]')?.addEventListener('click',()=>{const root=document.documentElement;const next=root.dataset.theme==='light'?'dark':'light';root.dataset.theme=next;localStorage.setItem('theme',next)});</script></body></html>
