---
const endpoint = import.meta.env.PUBLIC_GOATCOUNTER_ENDPOINT?.replace(/\/$/, '');
const enabled = Boolean(endpoint);
---
{enabled&&<script is:inline async src="https://gc.zgo.at/count.v5.js" data-goatcounter={`${endpoint}/count`} crossorigin="anonymous" integrity="sha384-atnOLvQb9t+jTSipvd75X2yginT4PjVbqDdlJAmxMm+wYElFmeR6EmLP5bYeoRVQ"></script>}
