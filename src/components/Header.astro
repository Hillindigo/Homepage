---
const { lang = 'zh', alternatePath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const other = lang === 'zh' ? 'en' : 'zh';
const nav = lang === 'zh' ? [['文章','writing'],['笔记','notes'],['项目','projects'],['生活','life'],['关于','about']] : [['Writing','writing'],['Notes','notes'],['Projects','projects'],['Life','life'],['About','about']];
const currentPath = Astro.url.pathname;
const languageHref = alternatePath || currentPath.replace(`/${lang}/`, `/${other}/`);
---
<header class="site-header"><nav class="nav glass">
  <a class="identity" href={`${base}/${lang}/`}><img src={`${base}/images/avatar.png`} alt="Hillindigo avatar"/><span>青山黛 · Hillindigo</span></a>
  <div class="nav-links">{nav.map(([label,path])=><a href={`${base}/${lang}/${path}/`} aria-current={currentPath.includes(`/${path}/`)?'page':undefined}>{label}</a>)}</div>
  <div class="nav-tools"><a data-search-link href={`${base}/${lang}/search/`} aria-keyshortcuts="/ Control+K Meta+K" title={lang==='zh'?'搜索（/ 或 Ctrl+K）':'Search (/ or Ctrl+K)'} aria-label={lang==='zh'?'搜索':'Search'}>⌕</a><a href={languageHref} aria-label={`${other.toUpperCase()} · ${lang==='zh'?'切换到英文':'Switch to Chinese'}`}>{other.toUpperCase()}</a><button data-theme-toggle aria-label={lang==='zh'?'切换深浅主题':'Toggle color theme'}>◐</button><details class="mobile-menu" data-mobile-menu data-open-label={lang==='zh'?'打开导航':'Open navigation'} data-close-label={lang==='zh'?'关闭导航':'Close navigation'}><summary aria-expanded="false" aria-label={lang==='zh'?'打开导航':'Open navigation'}>☰</summary><div>{nav.map(([label,path])=><a href={`${base}/${lang}/${path}/`} aria-current={currentPath.includes(`/${path}/`)?'page':undefined}>{label}<span>↗</span></a>)}</div></details></div>
</nav></header>
<script>
  const searchLink=document.querySelector<HTMLAnchorElement>('[data-search-link]');
  const mobileMenu=document.querySelector<HTMLDetailsElement>('[data-mobile-menu]');
  const mobileSummary=mobileMenu?.querySelector<HTMLElement>('summary');
  const syncMobileMenu=()=>{
    if(!mobileMenu||!mobileSummary)return;
    const expanded=mobileMenu.open;
    mobileSummary.setAttribute('aria-expanded',String(expanded));
    mobileSummary.setAttribute('aria-label',expanded?(mobileMenu.dataset.closeLabel??'Close navigation'):(mobileMenu.dataset.openLabel??'Open navigation'));
  };
  mobileMenu?.addEventListener('toggle',syncMobileMenu);
  mobileMenu?.querySelectorAll('a').forEach(link=>link.addEventListener('click',()=>{mobileMenu.open=false}));
  document.addEventListener('pointerdown',(event)=>{
    if(mobileMenu?.open&&event.target instanceof Node&&!mobileMenu.contains(event.target))mobileMenu.open=false;
  });
  const focusSearch=()=>{
    const input=document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
    if(input){input.focus();input.select();return true}
    return false;
  };
  document.addEventListener('keydown',(event)=>{
    if(event.key==='Escape'&&mobileMenu?.open){
      event.preventDefault();
      mobileMenu.open=false;
      mobileSummary?.focus();
      return;
    }
    const target=event.target;
    if(target instanceof HTMLElement&&(target.matches('input,textarea,select')||target.isContentEditable))return;
    const slash=event.key==='/'&&!event.ctrlKey&&!event.metaKey&&!event.altKey;
    const commandK=event.key.toLowerCase()==='k'&&(event.ctrlKey||event.metaKey);
    if(!slash&&!commandK)return;
    event.preventDefault();
    if(!focusSearch()&&searchLink)window.location.assign(searchLink.href);
  });
  syncMobileMenu();
</script>
