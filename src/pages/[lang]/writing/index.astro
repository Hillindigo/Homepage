---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
export function getStaticPaths(){return [{params:{lang:'zh'}},{params:{lang:'en'}}]}
const {lang='zh'}=Astro.params;const zh=lang==='zh';const base=import.meta.env.BASE_URL.replace(/\/$/,'');
const posts=(await getCollection('blog',({data})=>data.lang===lang&&!data.draft)).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const fmt=new Intl.DateTimeFormat(zh?'zh-CN':'en-US',{year:'numeric',month:'short',day:'numeric'});
---
<BaseLayout lang={lang} title={`${zh?'文章':'Writing'} · Hillindigo`}><main class="listing-page shell" data-pagefind-ignore><header class="listing-head"><p class="eyebrow">01 / WRITING</p><h1>{zh?'文章与研究':'Writing & Research'}</h1><p>{zh?'经过整理的技术实践、研究与长期思考。':'Considered notes on technical practice, research and durable ideas.'}</p></header><div class="post-list">{posts.map((post,i)=><a class="post-row" href={`${base}/${lang}/writing/${post.id.replace(`${lang}/`,'')}/`}><span class="post-index">{String(i+1).padStart(2,'0')}</span><div><div class="article-tags">{post.data.tags.map(tag=><span>{tag}</span>)}</div><h2>{post.data.title}</h2><p>{post.data.description}</p></div><time>{fmt.format(post.data.pubDate)}</time><b>↗</b></a>)}</div></main></BaseLayout>
