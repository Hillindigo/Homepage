---
import { getCollection, render } from 'astro:content';
import readingTime from 'reading-time';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { isVisibleContent } from '../../../lib/content';
export async function getStaticPaths(){const entries=await getCollection('notes',({data})=>isVisibleContent(data));return entries.map(entry=>({params:{lang:entry.data.lang,slug:entry.id.replace(`${entry.data.lang}/`,'')},props:{entry}}))}
const {entry}=Astro.props; const {Content,headings}=await render(entry); const minutes=Math.max(1,Math.ceil(readingTime(entry.body??'').minutes));
---
<ArticleLayout entry={entry} readingMinutes={minutes} headings={headings} section="NOTES" comments={false}><Content/></ArticleLayout>
