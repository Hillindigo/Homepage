---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang = 'zh' } = Astro.params;
const zh = lang === 'zh';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const collections = ['blog', 'notes', 'projects', 'life'] as const;
const groups = await Promise.all(
  collections.map((collection) =>
    getCollection(collection, ({ data }) => data.lang === lang && !data.draft),
  ),
);
const counts = new Map<string, number>();
for (const entry of groups.flat()) {
  for (const tag of entry.data.tags) counts.set(tag, (counts.get(tag) ?? 0) + 1);
}
const tags = [...counts.entries()].sort(
  ([nameA, countA], [nameB, countB]) => countB - countA || nameA.localeCompare(nameB, lang),
);
---

<BaseLayout
  lang={lang}
  title={`${zh ? '标签' : 'Tags'} · Hillindigo`}
  description={zh ? '按主题探索青山黛的文章、笔记、项目与生活记录。' : 'Explore Hillindigo by topic across writing, notes, projects and life.'}
>
  <main class="listing-page shell" data-pagefind-ignore>
    <header class="listing-head">
      <p class="eyebrow">HILLINDIGO / TAGS</p>
      <h1>{zh ? '主题索引' : 'Topic Index'}</h1>
      <p>{zh ? `从 ${tags.length} 个主题进入全部公开内容。` : `Explore all public entries through ${tags.length} topics.`}</p>
    </header>
    {tags.length > 0 ? (
      <div class="tag-cloud" aria-label={zh ? '全部标签' : 'All tags'}>
        {tags.map(([tag, count], index) => (
          <a href={`${base}/${lang}/tags/${encodeURIComponent(tag)}/`} style={`--tag-rank:${Math.min(index, 8)}`}>
            <span>#{tag}</span>
            <small>{String(count).padStart(2, '0')}</small>
          </a>
        ))}
      </div>
    ) : (
      <p class="collection-empty">{zh ? '暂时还没有公开标签。' : 'No public tags yet.'}</p>
    )}
  </main>
</BaseLayout>
