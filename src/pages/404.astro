---
import BaseLayout from '../layouts/BaseLayout.astro';
const base=import.meta.env.BASE_URL.replace(/\/$/,'');
---
<BaseLayout lang="zh" title="404 · Signal Lost · Hillindigo" description="The requested page could not be found." header={false} footer={false} alternatePath={`${base}/en/`}>
  <main class="not-found" data-not-found data-base={base}>
    <div class="grain"></div>
    <div class="not-found-orbit" aria-hidden="true"><i></i><i></i><i></i></div>
    <div class="not-found-content" data-not-found-view="zh">
      <p class="eyebrow">错误 / 404 / 信号丢失</p>
      <h1>这条轨道<br/>尚不存在</h1>
      <p>你访问的页面可能已经移动、改名，或者仍未被写下。</p>
      <div class="hero-actions"><a class="button primary" href={`${base}/zh/`}>返回首页</a><a class="button" href={`${base}/zh/search/`}>搜索内容 ↗</a></div>
    </div>
    <div class="not-found-content" data-not-found-view="en" hidden>
      <p class="eyebrow">ERROR / 404 / SIGNAL LOST</p>
      <h1>This orbit<br/>does not exist</h1>
      <p>The page may have moved, changed its name, or not been written yet.</p>
      <div class="hero-actions"><a class="button primary" href={`${base}/en/`}>Back home</a><a class="button" href={`${base}/en/search/`}>Search the site ↗</a></div>
    </div>
    <a class="not-found-brand" data-not-found-home href={`${base}/zh/`}><img src={`${base}/images/avatar.png`} alt=""/>青山黛 · Hillindigo</a>
  </main>
</BaseLayout>
<script>
  const root=document.querySelector<HTMLElement>('[data-not-found]');
  if(root){
    const siteBase=root.dataset.base??'';
    const relativePath=decodeURIComponent(location.pathname).slice(siteBase.length);
    const pathLanguage=relativePath.match(/^\/(zh|en)(?:\/|$)/)?.[1];
    const savedLanguage=localStorage.getItem('hillindigo-language');
    const browserLanguage=navigator.language.toLowerCase().startsWith('zh')?'zh':'en';
    const language=pathLanguage??(savedLanguage==='zh'||savedLanguage==='en'?savedLanguage:browserLanguage);
    document.documentElement.lang=language;
    document.title=language==='zh'?'404 · 信号丢失 · Hillindigo':'404 · Signal Lost · Hillindigo';
    root.querySelectorAll<HTMLElement>('[data-not-found-view]').forEach(view=>view.hidden=view.dataset.notFoundView!==language);
    root.querySelector<HTMLAnchorElement>('[data-not-found-home]')?.setAttribute('href',`${siteBase}/${language}/`);
    if(pathLanguage)localStorage.setItem('hillindigo-language',language);
  }
</script>
