{
  "name": "hillindigo-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:drafts": "node scripts/dev-drafts.mjs",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "check:content": "node scripts/check-content.mjs",
    "check:config": "node scripts/check-config.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:rss": "node scripts/check-rss.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:sitemap": "node scripts/check-sitemap.mjs",
    "validate": "npm run check:config && npm run check:content && npm run check && npm run build && npm run check:links && npm run check:rss && npm run check:sitemap && npm run check:seo",
    "new": "node scripts/new-content.mjs",
    "publish": "node scripts/publish-content.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.7",
    "pagefind": "^1.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^1.5.0",
    "typescript": "^6.0.3"
  }
}
